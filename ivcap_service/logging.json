{
  "version": 1,
  "formatters": {
    "default": {
      "format": "%(asctime)s %(levelname)s (%(name)s): %(message)s",
      "datefmt": "%Y-%m-%dT%H:%M:%S%z"
    }
  },
  "handlers": {
    "default": {
      "class": "logging.StreamHandler",
      "level": "DEBUG",
      "formatter": "default",
      "stream": "ext://sys.stderr"
    }
  },
  "root": {
    "level": "INFO",
    "handlers": [
      "default"
    ]
  },
  "loggers": {
    "app": {
      "level": "DEBUG"
    },
    "event": {
      "level": "DEBUG"
    },
    "ivcap": {
      "level": "DEBUG"
    },
    "opentelemetry": {
      "handlers": [
        "default"
      ],
      "level": "WARNING",
      "propagate": false
    },
    "opentelemetry.instrumentation": {
      "handlers": [
        "default"
      ],
      "level": "WARNING",
      "propagate": false
    },
    "opentelemetry.exporter": {
      "handlers": [
        "default"
      ],
      "level": "WARNING",
      "propagate": false
    },
    "opentelemetry.sdk": {
      "handlers": [
        "default"
      ],
      "level": "WARNING",
      "propagate": false
    },
    "opentelemetry.sdk.trace.export": {
      "handlers": [
        "default"
      ],
      "level": "ERROR",
      "propagate": false
    },
    "opentelemetry.sdk._logs": {
      "handlers": [
        "default"
      ],
      "level": "ERROR",
      "propagate": false
    },
    "opentelemetry.sdk.metrics": {
      "handlers": [
        "default"
      ],
      "level": "WARNING",
      "propagate": false
    }
  },
  "disable_existing_loggers": false
}